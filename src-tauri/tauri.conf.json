{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Codec",
  "version": "1.0.0",
  "identifier": "com.aicodec.app",
  "build": {
    "beforeDevCommand": "npx serve electron -l 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/copy-webview.js",
    "frontendDist": "../dist-webview"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Codec",
        "width": 1000,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "AI codec with Ollama, semantic index, and file tools",
    "shortDescription": "AI Codec",
    "resources": ["../backend", "../python-runtime"],
    "category": "DeveloperTool",
    "copyright": "",
    "license": null
  }
}
